# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=replace-with-production-secret
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com,admin.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com,https://admin.example.com
CMS_SITE_URL=https://www.example.com

# 镜像
BACKEND_IMAGE=ghcr.io/zhaoyongze123/cms-backend:latest
STUDIO_IMAGE=ghcr.io/zhaoyongze123/cms-studio-web:latest
PUBLIC_IMAGE=ghcr.io/zhaoyongze123/cms-public-web:latest

# Database
POSTGRES_DB=wagtailcms
POSTGRES_USER=wagtailcms
POSTGRES_PASSWORD=replace-with-production-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Internal Services
INTERNAL_API_TOKEN=replace-with-production-internal-token
AI_PROVIDER=mock
AI_PROMPT_VERSION=v1
AI_SERVICE_URL=http://ai-service:8000
DJANGO_INTERNAL_BASE_URL=http://web:8000
NEXT_PUBLIC_DJANGO_BASE_URL=https://admin.example.com
NEXT_PUBLIC_EDITOR_BASE_URL=https://admin.example.com
NEXT_PUBLIC_DJANGO_PUBLIC_BASE_URL=https://www.example.com
NEXT_PUBLIC_SITE_URL=https://www.example.com
NEXT_PUBLIC_AUTH_MODE=django-session

# SiliconFlow
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_CHAT_MODEL=Pro/zai-org/GLM-4.7
SILICONFLOW_FAST_MODEL=Qwen/Qwen3-32B
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
SILICONFLOW_EMBEDDING_DIMENSIONS=1536
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_PROVIDER=auto
RAG_DATABASE_URL=postgresql://wagtailcms:replace-with-production-db-password@db:5432/wagtailcms
RAG_CHUNK_TABLE=simple_cms_knowledgechunk
RAG_SOURCE_TABLE=simple_cms_knowledgesource
RAG_SOURCE_TYPE=article
RAG_ENABLE_RERANK=true
RAG_FORCE_MOCK=false
RAG_VECTOR_DIMENSIONS=1536
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80

# Aliyun
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_REGION=cn-hangzhou
ALIYUN_DNS_REGION=cn-hangzhou
ALIYUN_DNS_DOMAINS=example.com
ALIYUN_CMS_NAMESPACE=acs_ecs_dashboard
ALIYUN_CMS_METRICS=CPUUtilization,MemoryUtilization,InternetIn,InternetOut
