# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8001,http://127.0.0.1:8001

# Database
POSTGRES_DB=wagtailcms
POSTGRES_USER=wagtailcms
POSTGRES_PASSWORD=wagtailcms
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Internal Services
INTERNAL_API_TOKEN=change-me-to-a-long-random-string
AI_PROVIDER=mock
AI_PROMPT_VERSION=v1
AI_SERVICE_URL=http://ai-service:8000
DJANGO_INTERNAL_BASE_URL=http://web:8000
NEXT_PUBLIC_DJANGO_BASE_URL=http://127.0.0.1:8001
NEXT_PUBLIC_EDITOR_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_AUTH_MODE=django-session

# SiliconFlow
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_CHAT_MODEL=Pro/zai-org/GLM-4.7
SILICONFLOW_FAST_MODEL=Qwen/Qwen3-32B
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
SILICONFLOW_EMBEDDING_DIMENSIONS=1536
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_PROVIDER=auto
RAG_DATABASE_URL=postgresql://wagtailcms:wagtailcms@db:5432/wagtailcms
RAG_CHUNK_TABLE=simple_cms_knowledgechunk
RAG_SOURCE_TABLE=simple_cms_knowledgesource
RAG_SOURCE_TYPE=article
RAG_ENABLE_RERANK=true
RAG_FORCE_MOCK=false
RAG_VECTOR_DIMENSIONS=1536
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80

# Aliyun
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_REGION=cn-hangzhou
ALIYUN_DNS_REGION=cn-hangzhou
ALIYUN_DNS_DOMAINS=example.com
ALIYUN_CMS_NAMESPACE=acs_ecs_dashboard
ALIYUN_CMS_METRICS=CPUUtilization,MemoryUtilization,InternetIn,InternetOut
