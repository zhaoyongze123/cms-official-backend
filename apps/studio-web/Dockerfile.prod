FROM node:22-bookworm-slim AS runner

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV http_proxy=
ENV https_proxy=
ENV HTTP_PROXY=
ENV HTTPS_PROXY=
ENV all_proxy=
ENV ALL_PROXY=

WORKDIR /app

COPY apps/studio-web/.next/standalone /app
COPY apps/studio-web/.next/static /app/apps/studio-web/.next/static

WORKDIR /app/apps/studio-web

EXPOSE 3000

CMD ["node", "server.js"]
